{
  "name": "@opencode-hub/obsidian-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "OpenCode Hub plugin for Obsidian — AI sidebar with vault context.",
  "main": "dist/main.js",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --external:obsidian --external:electron --format=cjs --outfile=dist/main.js --platform=node --target=es2022",
    "dev": "esbuild src/main.ts --bundle --external:obsidian --external:electron --format=cjs --outfile=dist/main.js --platform=node --target=es2022 --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opencode-hub/client": "workspace:*",
    "@opencode-hub/protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.7.2",
    "typescript": "^5.8.0"
  }
}
